<div class="layout layout--col">
  <div class="x-canvas x-quadrant">
    <div class="x-header">
      <span class="x-title">Müllabfuhr</span>
      {% if has_pickups and next.badge != "" %}<span class="x-meta">{{ next.badge }}</span>{% endif %}
    </div>

    {% if has_pickups %}
    {% assign n = next %}
    <div class="x-content awrm-center">
      <div class="awrm-hero{% if n.is_soon %} awrm-hero--soon{% endif %}">
        <div class="awrm-date">{{ n.weekday_short }}, {{ n.date_human }}</div>
        <div class="awrm-items">
          {% for it in n.items %}
          <div class="awrm-item">
            <span class="awrm-tag">{{ it.tag }}</span>
            <span class="awrm-item-name">{{ it.name }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
    {% else %}
    <div class="x-content">
      <div class="awrm-empty">
        <div class="awrm-empty-title">Keine Termine</div>
      </div>
    </div>
    {% endif %}
  </div>
</div>
