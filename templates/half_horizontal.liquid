<div class="view view--half_horizontal">
  <div class="layout">
    {% if has_pickups %}
    <div class="columns">

      {% comment %} Hero (next) on the left {% endcomment %}
      <div class="column" style="flex: 0 0 50%; padding-right: 12px;">
        {% assign n = next %}
        <div style="border: 3px solid black; border-radius: 8px; height: 100%; box-sizing: border-box; padding: 10px 14px;
                    {% if n.is_soon %}background: black; color: white;{% endif %}">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Nächste Abfuhr</span>
            {% if n.badge != "" %}
            <span style="font-size: 16px; font-weight: 800; letter-spacing: 1px; padding: 1px 9px; border-radius: 4px;
                         {% if n.is_soon %}background:white;color:black;{% else %}background:black;color:white;{% endif %}">{{ n.badge }}</span>
            {% endif %}
          </div>
          <div style="font-size: 26px; font-weight: 700; margin-top: 6px; line-height: 1.05;">{{ n.items_text }}</div>
          <div style="font-size: 16px; font-weight: 600; margin-top: 6px;">{{ n.weekday_short }}, {{ n.date_human }}
            <span style="{% unless n.is_soon %}opacity:.7;{% endunless %}">· {{ n.relative }}</span>
          </div>
        </div>
      </div>

      {% comment %} Next few on the right {% endcomment %}
      <div class="column" style="flex: 1 1 50%;">
        {% for u in upcoming offset: 1 limit: 3 %}
        <div style="display:flex; align-items:center; padding: 5px 0; border-bottom: 2px solid black;">
          <div style="flex:0 0 52px; text-align:center;">
            <span style="font-size: 19px; font-weight: 800;">{{ u.day }}.{{ u.month }}</span>
            <span style="font-size: 12px; font-weight: 600;"> {{ u.weekday_short }}</span>
          </div>
          <div style="margin-left: 10px; font-size: 16px; font-weight: 600;">{{ u.items_text }}</div>
        </div>
        {% endfor %}
      </div>

    </div>
    {% else %}
    <div class="columns"><div class="column" style="text-align:center; padding-top:60px;">
      <span style="font-size:24px;font-weight:700;">Keine Termine</span>
    </div></div>
    {% endif %}
  </div>

  <div class="title_bar">
    <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
    <span class="title">Müllabfuhr</span>
    <span class="instance">{{ address }}</span>
  </div>
</div>
