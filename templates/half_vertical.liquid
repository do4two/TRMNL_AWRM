<div class="view view--half_vertical">
  <div class="layout">
    {% if has_pickups %}
    <div class="columns">
      <div class="column">

        {% assign n = next %}
        <div style="border: 3px solid black; border-radius: 8px; box-sizing: border-box; padding: 12px 14px;
                    {% if n.is_soon %}background: black; color: white;{% endif %}">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Nächste</span>
            {% if n.badge != "" %}
            <span style="font-size: 17px; font-weight: 800; letter-spacing: 1px; padding: 1px 9px; border-radius: 4px;
                         {% if n.is_soon %}background:white;color:black;{% else %}background:black;color:white;{% endif %}">{{ n.badge }}</span>
            {% endif %}
          </div>
          {% for it in n.items %}
          <div style="font-size: 28px; font-weight: 700; margin-top: 8px; line-height: 1.05;">{{ it.name }}</div>
          {% endfor %}
          <div style="font-size: 16px; font-weight: 600; margin-top: 8px;">{{ n.weekday }}, {{ n.date_human }}</div>
          <div style="font-size: 15px; {% unless n.is_soon %}opacity:.7;{% endunless %}">{{ n.relative }}</div>
        </div>

        <span class="label" style="display:block; margin-top: 12px; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Danach</span>
        {% for u in upcoming offset: 1 limit: 4 %}
        <div style="display:flex; align-items:center; padding: 7px 0; border-bottom: 2px solid black;">
          <div style="flex:0 0 54px;">
            <span style="font-size: 19px; font-weight: 800;">{{ u.day }}.{{ u.month }}</span>
            <span style="font-size: 12px; font-weight: 600;"> {{ u.weekday_short }}</span>
          </div>
          <div style="margin-left: 8px; font-size: 16px; font-weight: 600;">{{ u.items_text }}</div>
        </div>
        {% endfor %}

      </div>
    </div>
    {% else %}
    <div class="columns"><div class="column" style="text-align:center; padding-top:140px;">
      <span style="font-size:24px;font-weight:700;">Keine Termine</span>
    </div></div>
    {% endif %}
  </div>

  <div class="title_bar">
    <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
    <span class="title">Müllabfuhr</span>
    <span class="instance">{{ address }}</span>
  </div>
</div>
