<div class="view view--full">
  <div class="layout">

    {% if has_pickups %}
    <div class="columns">

      {% comment %} ---------- HERO: next pickup ---------- {% endcomment %}
      <div class="column" style="flex: 0 0 58%; padding-right: 14px;">
        {% assign n = next %}
        <div style="border: 4px solid black; border-radius: 10px; height: 100%; box-sizing: border-box; padding: 18px 20px;
                    {% if n.is_soon %}background: black; color: white;{% endif %}">

          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size: 22px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">
              Nächste Abfuhr
            </span>
            {% if n.badge != "" %}
            <span style="font-size: 26px; font-weight: 800; letter-spacing: 2px; padding: 4px 14px; border-radius: 6px;
                         {% if n.is_soon %}background: white; color: black;{% else %}background: black; color: white;{% endif %}">
              {{ n.badge }}
            </span>
            {% endif %}
          </div>

          <div style="font-size: 30px; font-weight: 600; margin-top: 14px;">
            {{ n.weekday }}, {{ n.date_human }}
          </div>
          <div style="font-size: 19px; margin-top: 2px; {% unless n.is_soon %}opacity: .7;{% endunless %}">
            {{ n.relative }}
          </div>

          <div style="margin-top: 18px;">
            {% for it in n.items %}
            <div style="display:flex; align-items:center; margin-bottom: 12px;">
              <span style="display:inline-block; min-width: 78px; text-align:center; font-size: 17px; font-weight: 800;
                           padding: 6px 8px; border: 3px solid {% if n.is_soon %}white{% else %}black{% endif %}; border-radius: 6px;
                           {% if n.is_soon %}color: white;{% endif %}">
                {{ it.tag }}
              </span>
              <span style="font-size: 38px; font-weight: 700; margin-left: 16px; line-height: 1;">
                {{ it.name }}
              </span>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {% comment %} ---------- LIST: following pickups ---------- {% endcomment %}
      <div class="column" style="flex: 1 1 42%;">
        <span class="label" style="font-size: 17px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">
          Danach
        </span>
        <div style="margin-top: 8px;">
          {% for u in upcoming offset: 1 limit: 5 %}
          <div style="display:flex; align-items:center; padding: 9px 0; border-bottom: 2px solid black;">
            <div style="flex: 0 0 60px; text-align:center;">
              <div style="font-size: 26px; font-weight: 800; line-height: 1;">{{ u.day }}.{{ u.month }}</div>
              <div style="font-size: 14px; font-weight: 600; text-transform: uppercase;">{{ u.weekday_short }}</div>
            </div>
            <div style="margin-left: 12px; font-size: 21px; font-weight: 600;">
              {{ u.items_text }}
              {% if u.badge != "" %}
              <span style="font-size: 13px; font-weight: 800; letter-spacing: 1px; padding: 1px 7px; margin-left: 6px;
                           background: black; color: white; border-radius: 4px;">{{ u.badge }}</span>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
    {% else %}
    <div class="columns">
      <div class="column">
        <div style="text-align:center; padding-top: 120px;">
          <div style="font-size: 32px; font-weight: 700;">Keine Termine</div>
          <div style="font-size: 18px; margin-top: 10px; opacity:.7;">{{ error }}</div>
        </div>
      </div>
    </div>
    {% endif %}

  </div>

  <div class="title_bar">
    <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
    <span class="title">Müllabfuhr</span>
    <span class="instance">{{ address }} · Stand {{ generated_at_human }}</span>
  </div>
</div>
