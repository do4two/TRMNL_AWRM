<div class="view view--quadrant">
  <div class="layout">
    {% if has_pickups %}
    {% assign n = next %}
    <div class="columns">
      <div class="column">
        <div style="border: 3px solid black; border-radius: 8px; box-sizing: border-box; padding: 10px 12px;
                    {% if n.is_soon %}background: black; color: white;{% endif %}">

          {% if n.badge != "" %}
          <div style="font-size: 18px; font-weight: 800; letter-spacing: 2px; text-align:center; margin-bottom: 4px;
                      padding: 2px 0; {% if n.is_soon %}background:white;color:black;{% else %}background:black;color:white;{% endif %} border-radius: 4px;">
            {{ n.badge }}
          </div>
          {% endif %}

          <div style="font-size: 24px; font-weight: 800; line-height: 1.05;">{{ n.items_text }}</div>
          <div style="font-size: 15px; font-weight: 600; margin-top: 5px;">{{ n.weekday_short }}, {{ n.date_human }}</div>
          {% if n.badge == "" %}
          <div style="font-size: 13px; opacity:.7;">{{ n.relative }}</div>
          {% endif %}
        </div>
      </div>
    </div>
    {% else %}
    <div class="columns"><div class="column" style="text-align:center; padding-top:50px;">
      <span style="font-size:18px;font-weight:700;">Keine Termine</span>
    </div></div>
    {% endif %}
  </div>

  <div class="title_bar">
    <span class="title">Müllabfuhr</span>
    <span class="instance">{{ address }}</span>
  </div>
</div>
